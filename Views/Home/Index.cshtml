@inject ApplyPannuBro.Data.ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = "Home";
    
    var settings = await DbContext.Settings.ToDictionaryAsync(s => s.Key, s => s.Value);
    var heroTitle = settings.GetValueOrDefault("HeroTitle", "APPLY PANNU BRO");
    var heroSubtitle = settings.GetValueOrDefault("HeroSubtitle", "One Stop Solution For All Your Needs");
    var searchPlaceholder = settings.GetValueOrDefault("SearchPlaceholder", "Search services (e.g. PAN, Aadhaar)...");
    var servicesBtnText = settings.GetValueOrDefault("ServicesButtonText", "அனைத்து சேவைகள்");
    var waBtnText = settings.GetValueOrDefault("WhatsappButtonText", "WhatsApp Now");
    var callBtnText = settings.GetValueOrDefault("CallButtonText", "Call Now");
    var jobUpdatesBtnText = settings.GetValueOrDefault("JobUpdatesButtonText", "📢 Government & Private Job Updates");
    
    var waNumber = settings.GetValueOrDefault("WhatsappNumber", "918525041700");
    var displayPhone = settings.GetValueOrDefault("DisplayPhone", "8525041700");
    var email = settings.GetValueOrDefault("Email", "applypannubro@gmail.com");
    var fbUrl = settings.GetValueOrDefault("FacebookUrl", "#");
    var igUrl = settings.GetValueOrDefault("InstagramUrl", "#");
    
    var servicesCount = await DbContext.Services.CountAsync(s => s.IsEnabled);
}

<section class="hero fade-in-up">
  <div class="container">
    <h1 class="dynamic-hero-title" style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.2; margin-bottom: 10px; background: linear-gradient(135deg, var(--primary-color), var(--accent-color)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">@heroTitle</h1>
    <p class="dynamic-hero-subtitle" style="font-size: clamp(1rem, 2.5vw, 1.25rem); color: var(--text-secondary); max-width: 800px; margin: 0 auto 30px; font-weight: 500;">@heroSubtitle</p>

    <div class="search-bar">
      <i class="fa-solid fa-search"></i>
      <input type="text" id="service-search" placeholder="@searchPlaceholder">
      <div id="search-suggestions" class="search-suggestions"></div>
    </div>

    <div class="hero-btns">
      <a href="/Home/Services" class="btn btn-primary btn-hero-main">@servicesBtnText <i class="fa-solid fa-arrow-right"></i></a>
      <div class="hero-btns-row">
        <a href="https://wa.me/@waNumber" target="_blank" class="btn btn-whatsapp dynamic-whatsapp-link"><i class="fa-brands fa-whatsapp"></i> @waBtnText</a>
        <a href="tel:+@waNumber" class="btn btn-call dynamic-phone-link"><i class="fa-solid fa-phone"></i> @callBtnText</a>
      </div>
      <a href="/Home/JobUpdates" id="btn-job-updates" class="btn btn-job-updates">
        @jobUpdatesBtnText
      </a>
    </div>
  </div>
</section>

<section id="why-us" class="trust-badges-section fade-in-up delay-200">
  <div class="container">
    <div class="trust-badges">
      <div class="trust-badge">
        <i class="fa-solid fa-shield-halved"></i>
        <span>நம்பகமான சேவை</span>
      </div>
      <div class="badge-separator">•</div>
      <div class="trust-badge">
        <i class="fa-solid fa-bolt"></i>
        <span>வேகமான சேவை</span>
      </div>
      <div class="badge-separator">•</div>
      <div class="trust-badge">
        <i class="fa-solid fa-user-tie"></i>
        <span>நிபுணர் ஆதரவு</span>
      </div>
      <div class="badge-separator">•</div>
      <div class="trust-badge">
        <i class="fa-solid fa-face-smile"></i>
        <span>100% திருப்தி</span>
      </div>
    </div>
  </div>
</section>

<section class="section-padding">
  <div class="container">
    <h2 class="section-title">Our Premium Services</h2>
    <p class="section-subtitle">Choose from our wide range of digital services</p>

    <div id="home-page-marker" style="display:none;"></div>

    <div class="category-filters">
      <button class="filter-btn active" data-filter="All">All</button>
      <button class="filter-btn" data-filter="Government">Government</button>
      <button class="filter-btn" data-filter="Education">Education</button>
      <button class="filter-btn" data-filter="Business">Business</button>
      <button class="filter-btn" data-filter="Payment">Payments & Booking</button>
    </div>

    <div id="dynamic-services-grid" class="services-grid">
      <!-- Rendered dynamically via API -->
    </div>

    <div style="text-align: center; margin-top: 40px;">
      <a href="/Home/Services" class="btn btn-primary">View All @servicesCount+ Services</a>
    </div>
  </div>
</section>

<section class="stats section-padding">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <h3 class="counter" data-target="@servicesCount">0</h3>
        <p>Services</p>
      </div>
      <div class="stat-item">
        <h3 class="counter" data-target="5000">0</h3>
        <p>Happy Customers</p>
      </div>
      <div class="stat-item">
        <h3><span class="counter" data-target="99">0</span>%</h3>
        <p>Success Rate</p>
      </div>
      <div class="stat-item">
        <h3>24x7</h3>
        <p>Support</p>
      </div>
    </div>
  </div>
</section>

<section class="reviews-section section-padding">
  <div class="container">
    <h2 class="section-title">Customer Reviews</h2>
    <p class="section-subtitle">What our happy clients say about us</p>

    <div class="reviews-container">
      <div class="reviews-track" id="dynamic-reviews-track">
        <!-- Rendered by slider.js -->
      </div>
    </div>
  </div>
</section>

<section class="section-padding" style="background: var(--bg-color);">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 50px;">

      <div>
        <h2 class="section-title" style="text-align: left;">Contact Us</h2>
        <p class="section-subtitle" style="text-align: left; margin-bottom: 30px;">Get in touch for instant support.</p>

        <div style="display: flex; gap: 20px; margin-bottom: 25px;">
          <div style="width: 50px; height: 50px; border-radius: 10px; background: rgba(37,99,235,0.1); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
            <i class="fa-brands fa-whatsapp"></i>
          </div>
          <div>
            <h4 style="margin-bottom: 5px;">WhatsApp / Call</h4>
            <p style="color: var(--text-secondary);" class="dynamic-phone-text">@displayPhone</p>
          </div>
        </div>

        <div style="display: flex; gap: 20px; margin-bottom: 25px;">
          <div style="width: 50px; height: 50px; border-radius: 10px; background: rgba(37,99,235,0.1); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
            <i class="fa-regular fa-envelope"></i>
          </div>
          <div>
            <h4 style="margin-bottom: 5px;">Email</h4>
            <p style="color: var(--text-secondary);" class="dynamic-email-text">@email</p>
          </div>
        </div>

        <div style="display: flex; gap: 20px;">
          <div style="width: 50px; height: 50px; border-radius: 10px; background: rgba(37,99,235,0.1); color: var(--primary-color); display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
            <i class="fa-solid fa-clock"></i>
          </div>
          <div>
            <h4 style="margin-bottom: 5px;">Working Hours</h4>
            <p style="color: var(--text-secondary);" class="dynamic-working-hours-text">@settings.GetValueOrDefault("WorkingHours", "24x7 Support Available")</p>
          </div>
        </div>
      </div>

      <div>
        <h2 class="section-title" style="text-align: left;">FAQ</h2>
        <p class="section-subtitle" style="text-align: left; margin-bottom: 30px;">Frequently Asked Questions</p>

        <div class="faq-list">
          <div class="faq-item">
            <div class="faq-question">PAN எப்படி Apply செய்வது? <i class="fa-solid fa-chevron-down"></i></div>
            <div class="faq-answer">
              <p>உங்கள் ஆதார் அட்டை மற்றும் புகைப்படம் இருந்தால் போதும். நாங்கள் ஆன்லைனில் விண்ணப்பித்து தருவோம்.</p>
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">Aadhaar Update எவ்வளவு நேரம்? <i class="fa-solid fa-chevron-down"></i></div>
            <div class="faq-answer">
              <p>விண்ணப்பித்த 3 முதல் 7 நாட்களுக்குள் மாற்றம் செய்யப்படும்.</p>
            </div>
          </div>
          <div class="faq-item">
            <div class="faq-question">WhatsApp மூலம் சேவை பெற முடியுமா? <i class="fa-solid fa-chevron-down"></i></div>
            <div class="faq-answer">
              <p>ஆம், உங்கள் ஆவணங்களை WhatsApp மூலம் அனுப்பி சேவைகளை பெற்றுக்கொள்ளலாம்.</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<div class="fab-wrapper" id="fab-wrapper">
  <div class="fab-menu" id="fab-menu">
    <a href="tel:+@waNumber" class="fab-item fab-item-call dynamic-phone-link">
      <span class="fab-label">Call</span>
      <div class="fab-icon-circle fab-call"><i class="fa-solid fa-phone"></i></div>
    </a>
    <a href="https://wa.me/@waNumber" target="_blank" class="fab-item fab-item-wa dynamic-whatsapp-link">
      <span class="fab-label">WhatsApp</span>
      <div class="fab-icon-circle fab-wa"><i class="fa-brands fa-whatsapp"></i></div>
    </a>
    <a href="@igUrl" target="_blank" class="fab-item fab-item-ig">
      <span class="fab-label">Instagram</span>
      <div class="fab-icon-circle fab-ig"><i class="fa-brands fa-instagram"></i></div>
    </a>
    <a href="@fbUrl" target="_blank" class="fab-item fab-item-fb">
      <span class="fab-label">Facebook</span>
      <div class="fab-icon-circle fab-fb"><i class="fa-brands fa-facebook-f"></i></div>
    </a>
    <a href="mailto:@email" class="fab-item fab-item-email dynamic-email-link">
      <span class="fab-label">Email</span>
      <div class="fab-icon-circle fab-email"><i class="fa-solid fa-envelope"></i></div>
    </a>
  </div>
  <button class="fab-main" id="fab-main" aria-label="Contact Us" aria-expanded="false">
    <i class="fa-solid fa-headset fab-icon-default"></i>
    <i class="fa-solid fa-xmark fab-icon-close"></i>
  </button>
</div>

@section Scripts {
  <script src="/js/slider.js"></script>
  <script src="/js/filter.js"></script>
  <script src="/js/search.js"></script>
}
