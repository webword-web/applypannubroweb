@{
    ViewData["Title"] = "Privacy Policy";
}

<div style="padding: 160px 0 80px; text-align: center; background: var(--surface-color); border-bottom: 1px solid var(--border-color);">
  <div class="container fade-in-up">
    <h1 class="section-title">Privacy Policy</h1>
    <p class="section-subtitle" style="margin-bottom: 0;">How we handle your data.</p>
  </div>
</div>

<section class="section-padding">
  <div class="container fade-in-up delay-100" style="max-width: 800px; background: var(--surface-color); padding: 40px; border-radius: 20px; border: 1px solid var(--border-color);">
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Information Collection</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">We collect personal information such as Name, Phone Number, Email, and necessary documents required for applying for government, educational, and business services on your behalf.</p>
    
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Data Security</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">We are committed to ensuring that your information is secure. Your documents (Aadhaar, PAN, etc.) are strictly used for application purposes and are securely deleted from our systems after successful completion of your service request.</p>

    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Cookies</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">We use cookies to improve your user experience and save preferences like Dark/Light mode theme.</p>
  </div>
</section>
