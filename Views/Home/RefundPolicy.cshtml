@{
    ViewData["Title"] = "Refund Policy";
}

<div style="padding: 160px 0 80px; text-align: center; background: var(--surface-color); border-bottom: 1px solid var(--border-color);">
  <div class="container fade-in-up">
    <h1 class="section-title">Refund Policy</h1>
  </div>
</div>

<section class="section-padding">
  <div class="container fade-in-up delay-100" style="max-width: 800px; background: var(--surface-color); padding: 40px; border-radius: 20px; border: 1px solid var(--border-color);">
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Cancellations</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">If you wish to cancel a service request before we have started the application process, a 100% refund will be provided within 3-5 working days.</p>
    
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Non-Refundable Scenarios</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">Once an application has been submitted to a government portal and official fees have been paid, no refunds can be issued under any circumstances.</p>

    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Rejections</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">If your application is rejected by the respective authority due to incorrect documents provided by you, the service fee is non-refundable. However, we will assist you in reapplying at a discounted rate.</p>
  </div>
</section>
