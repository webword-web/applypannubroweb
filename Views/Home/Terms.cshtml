@{
    ViewData["Title"] = "Terms & Conditions";
}

<div style="padding: 160px 0 80px; text-align: center; background: var(--surface-color); border-bottom: 1px solid var(--border-color);">
  <div class="container fade-in-up">
    <h1 class="section-title">Terms & Conditions</h1>
  </div>
</div>

<section class="section-padding">
  <div class="container fade-in-up delay-100" style="max-width: 800px; background: var(--surface-color); padding: 40px; border-radius: 20px; border: 1px solid var(--border-color);">
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Service Use</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">By using our services, you agree that you are providing accurate and authentic documents. Any rejection of applications due to fake or mismatched documents is solely the user's responsibility.</p>
    
    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Processing Delays</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">While we guarantee fast processing from our end, delays caused by government portals, server downtime, or verification processes are beyond our control.</p>

    <h2 style="margin-bottom: 20px; color: var(--primary-color);">Fees</h2>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">Our fees include the official government fee plus our nominal service charge. Prices are subject to change based on government revisions.</p>
  </div>
</section>
