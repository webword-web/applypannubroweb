rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is logged in
    function isAdmin() {
      return request.auth != null;
    }

    // Services collection: Anyone can read, only authenticated admins can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings collection: Anyone can read, only authenticated admins can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FAQs collection: Anyone can read, only authenticated admins can write
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials collection: Anyone can read, only authenticated admins can write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
