@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | APPLY PANNU BRO</title>
  <meta name="robots" content="noindex, nofollow">

  <!-- Fonts & Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- CSS Links -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <link rel="stylesheet" href="/css/admin.css">

  <style>
    /* Scope some overrides to keep admin clean */
    :root {
      --sidebar-width: 260px;
    }
    body {
      font-family: 'Poppins', sans-serif;
    }
    .admin-main-wrapper {
      display: flex;
      min-height: 100vh;
      width: 100%;
    }
    .admin-content-area {
      margin-left: var(--sidebar-width);
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      transition: margin-left 0.3s ease;
      background: var(--bg-color);
      width: calc(100% - var(--sidebar-width));
    }
    .admin-content-area.expanded {
      margin-left: 0;
      width: 100%;
    }
    .admin-sidebar {
      width: var(--sidebar-width);
      background: var(--surface-color);
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      z-index: 1000;
      transition: transform 0.3s ease;
    }
    .admin-sidebar.collapsed {
      transform: translateX(calc(-1 * var(--sidebar-width)));
    }
    .admin-tab {
      display: none;
      width: 100%;
      animation: fadeIn 0.4s ease;
    }
    .admin-tab.active {
      display: block;
    }
    .tab-container {
      padding: 30px;
    }
    .table-responsive {
      width: 100%;
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--surface-color);
      text-align: left;
    }
    th, td {
      padding: 14px 18px;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
      font-size: 0.92rem;
    }
    th {
      background: rgba(37, 99, 235, 0.05);
      font-weight: 600;
      color: var(--primary-color);
    }
    tr:hover td {
      background: rgba(37, 99, 235, 0.02);
    }
    .btn-sm {
      padding: 6px 12px;
      font-size: 0.82rem;
      border-radius: 6px;
    }
    .btn-danger {
      background: #ef4444;
      color: #fff;
    }
    .btn-danger:hover {
      background: #dc2626;
    }
    .btn-success {
      background: #10b981;
      color: #fff;
    }
    .btn-success:hover {
      background: #059669;
    }
    .btn-warning {
      background: #f59e0b;
      color: #fff;
    }
    .btn-warning:hover {
      background: #d97706;
    }
    .badge-role {
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 50px;
    }
    .role-super { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; }
    .role-admin { background: rgba(37, 99, 235, 0.15); color: #2563eb; }
    .role-staff { background: rgba(16, 185, 129, 0.15); color: #10b981; }

    /* File Manager UI */
    .file-manager-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }
    .file-card {
      background: var(--surface-color);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 15px;
      text-align: center;
      position: relative;
      transition: all 0.3s;
      overflow: hidden;
    }
    .file-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
    .file-preview {
      height: 80px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      margin-bottom: 10px;
      color: var(--text-secondary);
    }
    .file-preview img {
      max-height: 100%;
      max-width: 100%;
      border-radius: 6px;
      object-fit: cover;
    }
    .file-name {
      font-size: 0.78rem;
      color: var(--text-primary);
      text-overflow: ellipsis;
      white-space: nowrap;
      overflow: hidden;
      margin-bottom: 8px;
    }
    .file-actions {
      display: flex;
      justify-content: center;
      gap: 8px;
    }
    
    .folder-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background: var(--surface-color);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      color: var(--text-secondary);
      transition: all 0.3s;
    }
    .folder-btn.active {
      background: rgba(37, 99, 235, 0.1);
      color: var(--primary-color);
      border-color: var(--primary-color);
    }

    @@keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <!-- ===================== LOGIN SCREEN ===================== -->
  <div id="login-screen" class="admin-login-screen">
    <div class="login-box fade-in-up">
      <div class="login-logo">
        <i class="fa-solid fa-shield-halved"></i>
        <h1>Admin Access</h1>
        <p>APPLY PANNU BRO Dashboard</p>
      </div>
      <form id="login-form">
        <div class="form-group">
          <label><i class="fa-solid fa-user"></i> Username</label>
          <input type="text" id="admin-username" placeholder="Enter username" autocomplete="off" required>
        </div>
        <div class="form-group">
          <label><i class="fa-solid fa-lock"></i> Password</label>
          <div style="position:relative;">
            <input type="password" id="admin-password" placeholder="Enter password" autocomplete="off" required>
            <button type="button" onclick="togglePwd()" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-secondary);cursor:pointer;font-size:1rem;">
              <i class="fa-solid fa-eye" id="pwd-eye"></i>
            </button>
          </div>
        </div>
        <div id="login-error" class="login-error" style="display:none;"></div>
        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:10px;">Login to Dashboard</button>
      </form>
      <a href="/" style="display:block;text-align:center;margin-top:20px;color:var(--text-secondary);font-size:0.9rem;">
        <i class="fa-solid fa-arrow-left"></i> Back to Website
      </a>
    </div>
  </div>

  <!-- ===================== ADMIN DASHBOARD LAYOUT ===================== -->
  <div id="admin-dashboard" class="admin-main-wrapper" style="display:none;">

    <!-- Sidebar -->
    <aside class="admin-sidebar" id="admin-sidebar">
      <div class="sidebar-logo">
        <i class="fa-solid fa-shield-halved"></i>
        <span>Admin Panel</span>
      </div>
      <nav class="sidebar-nav" style="overflow-y:auto;height:calc(100vh - 150px);">
        <a class="sidebar-link active" data-tab="dashboard-tab">
          <i class="fa-solid fa-gauge"></i> Dashboard
        </a>
        <a class="sidebar-link" data-tab="jobs-tab">
          <i class="fa-solid fa-briefcase"></i> Manage Jobs
        </a>
        <a class="sidebar-link" data-tab="services-tab">
          <i class="fa-solid fa-server"></i> Manage Services
        </a>
        <a class="sidebar-link" data-tab="categories-tab">
          <i class="fa-solid fa-tags"></i> Categories
        </a>
        <a class="sidebar-link" data-tab="banners-tab">
          <i class="fa-solid fa-image"></i> Banners & Popups
        </a>
        <a class="sidebar-link super-admin-only" data-tab="users-tab" style="display:none;">
          <i class="fa-solid fa-users-cog"></i> User Management
        </a>
        <a class="sidebar-link" data-tab="contacts-tab">
          <i class="fa-solid fa-envelope-open-text"></i> Messages
        </a>
        <a class="sidebar-link" data-tab="file-manager-tab">
          <i class="fa-solid fa-folder-open"></i> File Manager
        </a>
        <a class="sidebar-link" data-tab="settings-tab">
          <i class="fa-solid fa-sliders"></i> Settings
        </a>
        <a class="sidebar-link admin-only" data-tab="backups-tab">
          <i class="fa-solid fa-database"></i> Database Backups
        </a>
        <a class="sidebar-link super-admin-only" data-tab="logs-tab" style="display:none;">
          <i class="fa-solid fa-history"></i> System Logs
        </a>
      </nav>
      <div class="sidebar-footer">
        <a href="/" target="_blank" class="sidebar-link">
          <i class="fa-solid fa-arrow-up-right-from-square"></i> View Website
        </a>
        <a class="sidebar-link" id="logout-btn">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
      </div>
    </aside>

    <!-- Main Content Area -->
    <main class="admin-content-area" id="admin-main-area">

      <!-- Top Bar -->
      <div class="admin-topbar">
        <button class="sidebar-toggle-btn" id="sidebar-toggle">
          <i class="fa-solid fa-bars"></i>
        </button>
        <h2 id="page-title">Dashboard</h2>
        <div style="display:flex;align-items:center;gap:15px;">
          <button id="admin-theme-toggle" class="theme-toggle" style="background:var(--surface-color);border:1px solid var(--border-color);width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-primary);">
            <i class="fa-solid fa-moon"></i>
          </button>
          <span style="color:var(--text-secondary);font-size:0.9rem;" id="welcome-username">Welcome, Admin</span>
          <div style="width:38px;height:38px;border-radius:50%;background:var(--primary-color);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1rem;">
            <i class="fa-solid fa-user"></i>
          </div>
        </div>
      </div>

      <!-- ===================== DASHBOARD TAB ===================== -->
      <div id="dashboard-tab" class="admin-tab active">
        <div class="tab-container">
          <div class="stats-cards" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
            <div class="stat-card">
              <div class="stat-card-icon" style="background:rgba(37,99,235,0.1);color:var(--primary-color);"><i class="fa-solid fa-users"></i></div>
              <div><h3 id="dash-users">0</h3><p>Total Users</p></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-icon" style="background:rgba(16,185,129,0.1);color:#10b981;"><i class="fa-solid fa-briefcase"></i></div>
              <div><h3 id="dash-jobs">0</h3><p>Active Jobs</p></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-icon" style="background:rgba(245,158,11,0.1);color:#f59e0b;"><i class="fa-solid fa-server"></i></div>
              <div><h3 id="dash-services">0</h3><p>Services</p></div>
            </div>
            <div class="stat-card">
              <div class="stat-card-icon" style="background:rgba(239,68,68,0.1);color:#ef4444;"><i class="fa-solid fa-eye"></i></div>
              <div><h3 id="dash-visitors">0</h3><p>Visitor Count</p></div>
            </div>
          </div>

          <div style="display:grid;grid-template-columns: 2fr 1fr;gap:20px;margin-top:30px;">
            <div class="admin-section-box">
              <h3 style="margin-bottom:20px;"><i class="fa-solid fa-history"></i> Recent Admin Activities</h3>
              <div class="table-responsive">
                <table id="dash-recent-activities">
                  <thead><tr><th>User</th><th>Action</th><th>Details</th><th>Time</th></tr></thead>
                  <tbody><tr><td colspan="4" style="text-align:center;">Loading activities...</td></tr></tbody>
                </table>
              </div>
            </div>
            <div class="admin-section-box">
              <h3 style="margin-bottom:20px;"><i class="fa-solid fa-user-plus"></i> Latest Users</h3>
              <div class="table-responsive">
                <table id="dash-latest-users">
                  <thead><tr><th>Username</th><th>Role</th></tr></thead>
                  <tbody><tr><td colspan="2" style="text-align:center;">Loading users...</td></tr></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== JOBS MANAGEMENT TAB ===================== -->
      <div id="jobs-tab" class="admin-tab">
        <div class="tab-container">
          <div class="admin-section-box">
            <div style="display:flex;justify-content:between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:15px;">
              <h3 style="margin:0;"><i class="fa-solid fa-briefcase"></i> Job Directory</h3>
              <button onclick="openJobModal()" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New Job</button>
            </div>
            <div class="services-toolbar" style="margin-bottom:20px;">
              <div class="admin-search-bar" style="max-width:300px;">
                <i class="fa-solid fa-search"></i>
                <input type="text" id="job-search" placeholder="Search jobs...">
              </div>
              <div style="display:flex;gap:10px;">
                <select id="job-filter-category" class="form-group" style="margin:0;width:150px;padding:8px 12px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-color);color:var(--text-primary);">
                  <option value="">All Categories</option>
                </select>
                <select id="job-filter-status" class="form-group" style="margin:0;width:120px;padding:8px 12px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-color);color:var(--text-primary);">
                  <option value="">All Status</option>
                  <option value="true">Active</option>
                  <option value="false">Inactive</option>
                </select>
              </div>
            </div>

            <div class="table-responsive">
              <table id="jobs-table">
                <thead>
                  <tr>
                    <th>Logo</th>
                    <th>Organization</th>
                    <th>Vacancy</th>
                    <th>Category</th>
                    <th>Last Date</th>
                    <th>Featured</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="jobs-list">
                  <tr><td colspan="8" style="text-align:center;">Loading jobs...</td></tr>
                </tbody>
              </table>
            </div>
            <!-- Pagination -->
            <div style="display:flex;justify-content:between;align-items:center;margin-top:20px;" id="jobs-pagination">
              <span id="jobs-page-info" style="color:var(--text-secondary);font-size:0.9rem;">Page 1 of 1</span>
              <div style="display:flex;gap:10px;">
                <button class="btn btn-outline" id="btn-jobs-prev" disabled>Previous</button>
                <button class="btn btn-outline" id="btn-jobs-next" disabled>Next</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== SERVICES MANAGEMENT TAB ===================== -->
      <div id="services-tab" class="admin-tab">
        <div class="tab-container">
          <div class="admin-section-box">
            <div style="display:flex;justify-content:between;align-items:center;margin-bottom:20px;flex-wrap:wrap;gap:15px;">
              <h3 style="margin:0;"><i class="fa-solid fa-server"></i> Services Catalog</h3>
              <button onclick="openServiceModal()" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add New Service</button>
            </div>
            <div class="services-toolbar" style="margin-bottom:20px;">
              <div class="admin-search-bar" style="max-width:300px;">
                <i class="fa-solid fa-search"></i>
                <input type="text" id="svc-search-input" placeholder="Search services...">
              </div>
              <div class="admin-filter-btns">
                <button class="adm-filter active" data-status="all">All</button>
                <button class="adm-filter" data-status="available">Available</button>
                <button class="adm-filter" data-status="coming-soon">Coming Soon</button>
                <button class="adm-filter" data-status="not-available">Not Available</button>
              </div>
            </div>

            <div id="admin-services-list" class="admin-services-grid">
              <!-- Rendered via API -->
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== CATEGORIES MANAGEMENT TAB ===================== -->
      <div id="categories-tab" class="admin-tab">
        <div class="tab-container" style="display:grid;grid-template-columns:1fr 2fr;gap:30px;">
          
          <!-- Category Form -->
          <div class="admin-section-box">
            <h3 id="category-form-title" style="margin-bottom:20px;">Create Category</h3>
            <form id="category-form">
              <input type="hidden" id="cat-id">
              <div class="form-group">
                <label>Category Name *</label>
                <input type="text" id="cat-name" placeholder="e.g. Banking" required>
              </div>
              <div class="form-group">
                <label>Icon Class *</label>
                <input type="text" id="cat-icon" placeholder="e.g. fa-solid fa-building-columns" required>
              </div>
              <div class="form-group">
                <label>Theme Color *</label>
                <input type="color" id="cat-color" value="#2563eb" style="padding:0;height:45px;cursor:pointer;" required>
              </div>
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" id="cat-order" value="0">
              </div>
              <div style="display:flex;gap:10px;margin-top:20px;">
                <button type="submit" class="btn btn-primary" id="cat-submit-btn"><i class="fa-solid fa-plus"></i> Save</button>
                <button type="button" onclick="resetCategoryForm()" class="btn btn-outline">Cancel</button>
              </div>
            </form>
          </div>

          <!-- Category List -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;">Existing Categories</h3>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Display Order</th>
                    <th>Icon</th>
                    <th>Name</th>
                    <th>Color</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="categories-list">
                  <!-- Rendered dynamically -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== BANNERS MANAGEMENT TAB ===================== -->
      <div id="banners-tab" class="admin-tab">
        <div class="tab-container" style="display:grid;grid-template-columns:1fr 2fr;gap:30px;">
          
          <!-- Form -->
          <div class="admin-section-box">
            <h3 id="banner-form-title" style="margin-bottom:20px;">Manage Banner</h3>
            <form id="banner-form">
              <input type="hidden" id="banner-id">
              <div class="form-group">
                <label>Title *</label>
                <input type="text" id="banner-title" placeholder="e.g. Special Offer" required>
              </div>
              <div class="form-group">
                <label>Type *</label>
                <select id="banner-type" required>
                  <option value="SliderImage">Slider Image</option>
                  <option value="HomepageBanner">Homepage Banner</option>
                  <option value="PopupBanner">Popup Alert</option>
                  <option value="Announcement">Ticker Announcement</option>
                </select>
              </div>
              <div class="form-group">
                <label>Image URL</label>
                <input type="text" id="banner-image-url" placeholder="Paste image path or upload via File Manager">
              </div>
              <div class="form-group">
                <label>Link Target URL</label>
                <input type="text" id="banner-link" placeholder="e.g. https://wa.me/...">
              </div>
              <div class="form-group">
                <label>Text Content (Optional)</label>
                <textarea id="banner-content" rows="3" placeholder="Announcements text details..."></textarea>
              </div>
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" id="banner-order" value="0">
              </div>
              <div class="form-group">
                <label>Status</label>
                <select id="banner-status">
                  <option value="true">Active</option>
                  <option value="false">Inactive</option>
                </select>
              </div>
              <div style="display:flex;gap:10px;margin-top:20px;">
                <button type="submit" class="btn btn-primary" id="banner-submit-btn"><i class="fa-solid fa-plus"></i> Save Banner</button>
                <button type="button" onclick="resetBannerForm()" class="btn btn-outline">Cancel</button>
              </div>
            </form>
          </div>

          <!-- List -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;">Current Banners & Announcements</h3>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Type</th>
                    <th>Title</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="banners-list">
                  <!-- Rendered dynamically -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== USER MANAGEMENT TAB ===================== -->
      <div id="users-tab" class="admin-tab">
        <div class="tab-container" style="display:grid;grid-template-columns:1fr 2fr;gap:30px;">
          
          <!-- User Form -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;">Create Admin Account</h3>
            <form id="user-form">
              <div class="form-group">
                <label>Username *</label>
                <input type="text" id="usr-username" placeholder="Enter username" autocomplete="off" required>
              </div>
              <div class="form-group">
                <label>Password *</label>
                <input type="password" id="usr-password" placeholder="Enter password" autocomplete="off" required>
              </div>
              <div class="form-group">
                <label>System Role *</label>
                <select id="usr-role" required>
                  <option value="Staff">Staff</option>
                  <option value="Admin">Admin</option>
                  <option value="SuperAdmin">Super Admin</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;margin-top:10px;"><i class="fa-solid fa-user-plus"></i> Add User</button>
            </form>
          </div>

          <!-- User List -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;">Active Accounts</h3>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Last Login</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="users-list">
                  <!-- Rendered dynamically -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== MESSAGES TAB ===================== -->
      <div id="contacts-tab" class="admin-tab">
        <div class="tab-container">
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-envelope-open-text"></i> Contact Messages</h3>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Sender Info</th>
                    <th>Message Details</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="contacts-list">
                  <!-- Rendered dynamically -->
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== FILE MANAGER TAB ===================== -->
      <div id="file-manager-tab" class="admin-tab">
        <div class="tab-container">
          <div class="admin-section-box">
            <div style="display:flex;justify-content:between;align-items:center;margin-bottom:25px;flex-wrap:wrap;gap:15px;">
              <div style="display:flex;gap:10px;" id="fm-folders">
                <button class="folder-btn active" data-folder="general"><i class="fa-solid fa-folder"></i> General Uploads</button>
                <button class="folder-btn" data-folder="logos"><i class="fa-solid fa-folder-closed"></i> Logos</button>
                <button class="folder-btn" data-folder="pdfs"><i class="fa-solid fa-folder-closed"></i> Job PDFs</button>
                <button class="folder-btn" data-folder="banners"><i class="fa-solid fa-folder-closed"></i> Banners</button>
              </div>
              <form id="fm-upload-form" style="display:flex;gap:10px;align-items:center;">
                <input type="file" id="fm-file-input" style="display:none;" required>
                <button type="button" onclick="document.getElementById('fm-file-input').click()" class="btn btn-outline"><i class="fa-solid fa-file-arrow-up"></i> Choose File</button>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-upload"></i> Upload</button>
              </form>
            </div>

            <div id="fm-files-grid" class="file-manager-grid">
              <!-- Rendered dynamically -->
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== SETTINGS TAB ===================== -->
      <div id="settings-tab" class="admin-tab">
        <div class="tab-container">
          <div class="admin-section-box" style="max-width:800px;">
            <form id="settings-form">
              
              <h3 style="margin-bottom:20px;border-bottom:1px solid var(--border-color);padding-bottom:8px;color:var(--primary-color);"><i class="fa-solid fa-globe"></i> General Settings</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Website Name</label>
                  <input type="text" id="set-WebsiteName" name="WebsiteName">
                </div>
                <div class="form-group">
                  <label>Footer Copyright Year</label>
                  <input type="text" id="set-CopyrightYear" name="CopyrightYear">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Logo Path / URL</label>
                  <input type="text" id="set-LogoUrl" name="LogoUrl">
                </div>
                <div class="form-group">
                  <label>Favicon Path / URL</label>
                  <input type="text" id="set-FaviconUrl" name="FaviconUrl">
                </div>
              </div>

              <h3 style="margin-bottom:20px;margin-top:35px;border-bottom:1px solid var(--border-color);padding-bottom:8px;color:var(--primary-color);"><i class="fa-solid fa-address-book"></i> Contact Details</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>WhatsApp Number (With Country Code, e.g. 918525...)</label>
                  <input type="text" id="set-WhatsappNumber" name="WhatsappNumber">
                </div>
                <div class="form-group">
                  <label>Display Phone Number</label>
                  <input type="text" id="set-DisplayPhone" name="DisplayPhone">
                </div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Support Email</label>
                  <input type="email" id="set-Email" name="Email">
                </div>
                <div class="form-group">
                  <label>Working Hours Text</label>
                  <input type="text" id="set-WorkingHours" name="WorkingHours">
                </div>
              </div>

              <h3 style="margin-bottom:20px;margin-top:35px;border-bottom:1px solid var(--border-color);padding-bottom:8px;color:var(--primary-color);"><i class="fa-solid fa-share-nodes"></i> Social Links</h3>
              <div class="form-row">
                <div class="form-group">
                  <label>Facebook Page Link</label>
                  <input type="url" id="set-FacebookUrl" name="FacebookUrl">
                </div>
                <div class="form-group">
                  <label>Instagram Link</label>
                  <input type="url" id="set-InstagramUrl" name="InstagramUrl">
                </div>
              </div>

              <h3 style="margin-bottom:20px;margin-top:35px;border-bottom:1px solid var(--border-color);padding-bottom:8px;color:var(--primary-color);"><i class="fa-solid fa-search"></i> SEO & Analytics</h3>
              <div class="form-group">
                <label>SEO Meta Description</label>
                <textarea id="set-SEOMetaDescription" name="SEOMetaDescription" rows="3"></textarea>
              </div>
              <div class="form-group">
                <label>Google Analytics Tracking ID (G-XXXXXXX)</label>
                <input type="text" id="set-GoogleAnalyticsId" name="GoogleAnalyticsId">
              </div>

              <!-- SMTP Section (Only enabled for Edit for SuperAdmin) -->
              <div id="smtp-settings-sec" style="display:none;">
                <h3 style="margin-bottom:20px;margin-top:35px;border-bottom:1px solid var(--border-color);padding-bottom:8px;color:var(--primary-color);"><i class="fa-solid fa-envelope"></i> SMTP Email Server Settings (Super Admin Only)</h3>
                <div class="form-row">
                  <div class="form-group">
                    <label>SMTP Host</label>
                    <input type="text" id="set-SmtpHost" name="SmtpHost">
                  </div>
                  <div class="form-group">
                    <label>SMTP Port</label>
                    <input type="number" id="set-SmtpPort" name="SmtpPort">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label>SMTP Username</label>
                    <input type="text" id="set-SmtpUsername" name="SmtpUsername">
                  </div>
                  <div class="form-group">
                    <label>SMTP Password</label>
                    <input type="password" id="set-SmtpPassword" name="SmtpPassword">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label>Sender Name</label>
                    <input type="text" id="set-SmtpSenderName" name="SmtpSenderName">
                  </div>
                  <div class="form-group">
                    <label>Sender Email</label>
                    <input type="email" id="set-SmtpSenderEmail" name="SmtpSenderEmail">
                  </div>
                </div>
              </div>

              <div style="margin-top:30px;">
                <button type="submit" class="btn btn-primary" style="padding:12px 30px;"><i class="fa-solid fa-floppy-disk"></i> Save All Settings</button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- ===================== DATABASE BACKUPS TAB ===================== -->
      <div id="backups-tab" class="admin-tab">
        <div class="tab-container" style="display:grid;grid-template-columns:1fr 1fr;gap:30px;">
          
          <!-- System Backup -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-database"></i> SQL Database Backups</h3>
            <p style="color:var(--text-secondary);margin-bottom:20px;font-size:0.92rem;">Perform database backup operations or restore the database structure and records from older backup files (.bak).</p>
            <button id="btn-create-backup" class="btn btn-primary"><i class="fa-solid fa-circle-arrow-down"></i> Create Database Backup</button>
            
            <h4 style="margin-top:30px;margin-bottom:15px;">Restore Database</h4>
            <div class="table-responsive">
              <table>
                <thead>
                  <tr>
                    <th>Filename</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="backups-list-tbody">
                  <!-- Rendered dynamically -->
                </tbody>
              </table>
            </div>
          </div>

          <!-- Data Exports -->
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-file-excel"></i> Export Directory Data</h3>
            <p style="color:var(--text-secondary);margin-bottom:25px;font-size:0.92rem;">Export system data records into CSV spreadsheet formats compatible with Microsoft Excel and Google Sheets.</p>
            <div style="display:flex;flex-direction:column;gap:12px;">
              <a href="/api/backups/export/jobs" class="btn btn-outline" style="text-align:left;display:block;"><i class="fa-solid fa-file-csv"></i> Export All Jobs to CSV</a>
              <a href="/api/backups/export/services" class="btn btn-outline" style="text-align:left;display:block;"><i class="fa-solid fa-file-csv"></i> Export All Services to CSV</a>
              <a href="/api/backups/export/users" class="btn btn-outline" style="text-align:left;display:block;"><i class="fa-solid fa-file-csv"></i> Export Active Users to CSV</a>
              <a href="/api/backups/export/settings" class="btn btn-outline" style="text-align:left;display:block;"><i class="fa-solid fa-file-csv"></i> Export Configuration Settings to CSV</a>
              <a href="/api/backups/export/contacts" class="btn btn-outline" style="text-align:left;display:block;"><i class="fa-solid fa-file-csv"></i> Export Contact Messages to CSV</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ===================== SYSTEM AUDIT LOGS TAB ===================== -->
      <div id="logs-tab" class="admin-tab">
        <div class="tab-container" style="display:grid;grid-template-rows:auto auto;gap:30px;">
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-clock-rotate-left"></i> General User Activity History</h3>
            <div class="table-responsive">
              <table id="logs-activity-table">
                <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Details</th><th>IP Address</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
          <div class="admin-section-box">
            <h3 style="margin-bottom:20px;"><i class="fa-solid fa-user-shield"></i> Detailed Data Modification Audits</h3>
            <div class="table-responsive">
              <table id="logs-audit-table">
                <thead><tr><th>Time</th><th>User</th><th>Action</th><th>Table</th><th>ID</th><th>Before Change</th><th>After Change</th><th>IP</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- ============================================================
       MODAL WINDOWS
  ============================================================ -->

  <!-- Add/Edit Job Modal -->
  <div id="job-modal" class="modal-overlay" style="display:none; z-index: 2000;">
    <div class="modal-box" style="max-width: 800px; max-height: 90vh; overflow-y: auto;">
      <div class="modal-header">
        <h3 id="job-modal-title">Add Job</h3>
        <button onclick="closeJobModal()" class="modal-close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="job-form">
        <input type="hidden" id="job-id">
        <div class="form-row">
          <div class="form-group">
            <label>Organization *</label>
            <input type="text" id="job-org" placeholder="e.g. Railway Recruitment Board" required>
          </div>
          <div class="form-group">
            <label>Short Code *</label>
            <input type="text" id="job-org-short" placeholder="e.g. RRB" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Vacancy Count *</label>
            <input type="number" id="job-vacancy" required>
          </div>
          <div class="form-group">
            <label>Category *</label>
            <select id="job-category" required>
              <option value="">Select Category</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Qualification/Eligibility *</label>
            <input type="text" id="job-eligibility" placeholder="e.g. ITI, Diploma, BE/BTech" required>
          </div>
          <div class="form-group">
            <label>Last Date *</label>
            <input type="date" id="job-lastdate" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Apply Link *</label>
            <input type="url" id="job-link" placeholder="e.g. https://wa.me/..." required>
          </div>
          <div class="form-group">
            <label>Badge</label>
            <select id="job-badge">
              <option value="NEW">NEW</option>
              <option value="TODAY">TODAY</option>
              <option value="LAST DATE">LAST DATE</option>
              <option value="">No Badge</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Salary (optional)</label>
            <input type="text" id="job-salary" placeholder="e.g. ₹25,000 - ₹60,000">
          </div>
          <div class="form-group">
            <label>Experience Needed</label>
            <input type="text" id="job-experience" placeholder="e.g. Freshers or 2 Years">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Job Type</label>
            <input type="text" id="job-type" placeholder="e.g. Full Time, Government">
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" id="job-location" placeholder="e.g. Tamil Nadu, Chennai">
          </div>
        </div>
        <div class="form-group">
          <label>Required Skills (Comma separated)</label>
          <input type="text" id="job-skills" placeholder="e.g. Typewriting, Basic Computer">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Logo Image URL</label>
            <input type="text" id="job-logo-url" placeholder="/logo/rrb.png">
          </div>
          <div class="form-group">
            <label>PDF Notification URL</label>
            <input type="text" id="job-pdf-url" placeholder="/uploads/pdfs/rrb.pdf">
          </div>
        </div>
        <div class="form-group">
          <label>Rich Text Description</label>
          <textarea id="job-desc" rows="6" placeholder="Enter detailed HTML description here..."></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Status</label>
            <select id="job-active">
              <option value="true">Active</option>
              <option value="false">Inactive</option>
            </select>
          </div>
          <div class="form-group">
            <label>Featured</label>
            <select id="job-featured">
              <option value="false">Standard</option>
              <option value="true">Featured on Homepage</option>
            </select>
          </div>
        </div>
        <div style="display:flex;gap:15px;margin-top:15px;">
          <button type="submit" class="btn btn-primary" style="flex:1;"><i class="fa-solid fa-floppy-disk"></i> Save Job</button>
          <button type="button" onclick="closeJobModal()" class="btn btn-outline" style="flex:1;">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add/Edit Service Modal -->
  <div id="service-modal" class="modal-overlay" style="display:none; z-index: 2000;">
    <div class="modal-box" style="max-width: 600px;">
      <div class="modal-header">
        <h3 id="svc-modal-title">Add Service</h3>
        <button onclick="closeServiceModal()" class="modal-close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="svc-form">
        <input type="hidden" id="svc-id">
        <div class="form-row">
          <div class="form-group">
            <label>Service Name *</label>
            <input type="text" id="svc-name" placeholder="e.g. PAN Card Apply" required>
          </div>
          <div class="form-group">
            <label>Category *</label>
            <select id="svc-category" required>
              <option value="Government">Government</option>
              <option value="Education">Education</option>
              <option value="Business">Business</option>
              <option value="Payment">Payment</option>
              <option value="Booking">Booking</option>
              <option value="Travel">Travel</option>
              <option value="Recharge">Recharge</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Description *</label>
          <textarea id="svc-desc" rows="3" placeholder="Brief details about documents needed..." required></textarea>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Pricing Info</label>
            <input type="text" id="svc-price" placeholder="e.g. ₹200 or Free">
          </div>
          <div class="form-group">
            <label>FontAwesome Icon Class</label>
            <input type="text" id="svc-icon" placeholder="e.g. fa-solid fa-id-card">
          </div>
        </div>
        <div class="form-group">
          <label>Service Image URL</label>
          <input type="text" id="svc-image" placeholder="/uploads/images/pan.png">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Status</label>
            <select id="svc-status">
              <option value="available">✅ Available</option>
              <option value="coming-soon">🟡 Coming Soon</option>
              <option value="not-available">🔴 Not Available</option>
            </select>
          </div>
          <div class="form-group">
            <label>Visibility</label>
            <select id="svc-enabled">
              <option value="true">👁 Visible</option>
              <option value="false">🙈 Hidden</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" id="svc-order" value="0">
        </div>
        <div style="display:flex;gap:15px;margin-top:15px;">
          <button type="submit" class="btn btn-primary" style="flex:1;"><i class="fa-solid fa-floppy-disk"></i> Save Service</button>
          <button type="button" onclick="closeServiceModal()" class="btn btn-outline" style="flex:1;">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Contact Reply Modal -->
  <div id="reply-modal" class="modal-overlay" style="display:none; z-index: 2000;">
    <div class="modal-box" style="max-width:600px;">
      <div class="modal-header">
        <h3>Reply to Contact Message</h3>
        <button onclick="closeReplyModal()" class="modal-close"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="reply-form">
        <input type="hidden" id="reply-msg-id">
        <div class="form-group">
          <label>Sender</label>
          <input type="text" id="reply-sender-name" readonly style="background:var(--bg-color);">
        </div>
        <div class="form-group">
          <label>User Inquiry</label>
          <div id="reply-user-message" style="background:var(--bg-color);padding:15px;border-radius:10px;border:1px solid var(--border-color);font-size:0.9rem;white-space:pre-line;color:var(--text-secondary);max-height:150px;overflow-y:auto;"></div>
        </div>
        <div class="form-group">
          <label>Your Reply Message (Will be emailed to the sender) *</label>
          <textarea id="reply-text" rows="5" placeholder="Write your reply here..." required></textarea>
        </div>
        <div style="display:flex;gap:15px;margin-top:15px;">
          <button type="submit" id="reply-submit-btn" class="btn btn-primary" style="flex:1;"><i class="fa-solid fa-paper-plane"></i> Send Reply</button>
          <button type="button" onclick="closeReplyModal()" class="btn btn-outline" style="flex:1;">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Confirm Modal -->
  <div id="delete-modal" class="modal-overlay" style="display:none; z-index: 3000;">
    <div class="modal-box" style="max-width:450px;text-align:center;">
      <div style="font-size:3rem;color:#ef4444;margin-bottom:15px;"><i class="fa-solid fa-triangle-exclamation"></i></div>
      <h3 id="delete-modal-title">Delete Item?</h3>
      <p style="color:var(--text-secondary);margin:15px 0;" id="delete-modal-text">This action cannot be undone. It will be permanently removed.</p>
      <div style="display:flex;gap:15px;justify-content:center;">
        <button id="confirm-delete-btn" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Yes, Delete</button>
        <button onclick="closeDeleteModal()" class="btn btn-outline">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Toast Notifications -->
  <div id="toast" class="admin-toast"></div>

  <!-- Scripts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/admin.js"></script>
</body>
</html>
